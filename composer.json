{
  "name": "poshtive/router",
  "description": "Convention-based route discovery for Laravel controllers using PHP attributes.",
  "type": "laravel-package",
  "license": "MIT",
  "keywords": [
    "laravel",
    "router",
    "routing",
    "attributes",
    "discovery"
  ],
  "autoload": {
    "psr-4": {
      "Poshtive\\Router\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    },
    "files": [
      "stubs/laravel_helpers.php"
    ]
  },
  "require": {
    "php": "^8.3",
    "illuminate/contracts": "^13.0",
    "illuminate/support": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/pipeline": "^13.0",
    "symfony/finder": "^7.4"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.1",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5.50"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.3.0"
    }
  },
  "scripts": {
    "analyse": "vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=512M",
    "test": "vendor/bin/phpunit --configuration phpunit.xml.dist",
    "test:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --configuration phpunit.xml.dist --coverage-clover coverage.xml && php scripts/check-coverage.php coverage.xml 100"
  },
  "support": {
    "issues": "https://github.com/poshtive/laravel-router/issues",
    "source": "https://github.com/poshtive/laravel-router"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Poshtive\\Router\\RouterServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
