{
  "name": "poshtive/router",
  "type": "laravel-package",
  "version": "0.1.2",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Poshtive\\Router\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    },
    "files": [
      "stubs/laravel_helpers.php"
    ]
  },
  "require": {
    "php": "^8.3",
    "illuminate/contracts": "^13.0",
    "illuminate/support": "^13.0",
    "illuminate/routing": "^13.0",
    "illuminate/pipeline": "^13.0",
    "symfony/finder": "~8.0.5"
  },
  "require-dev": {
    "mockery/mockery": "^1.6",
    "orchestra/testbench": "^11.0",
    "phpunit/phpunit": "^11.5"
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "test": "vendor/bin/phpunit --configuration phpunit.xml.dist"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Poshtive\\Router\\RouterServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
